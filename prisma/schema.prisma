// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
    provider      = "prisma-client"
    output        = "../src/generated/prisma"
    // previewFeatures = ["queryCompiler", "driverAdapters"]
    moduleFormat  = "esm"
    binaryTargets = ["native"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
    id             String    @id @default(uuid(7)) @db.VarChar(36)
    email          String    @unique @db.VarChar(320)
    firstName      String?   @map("first_name") @db.VarChar(255)
    lastName       String?   @map("last_name") @db.VarChar(255)
    hashedPassword String    @map("hashed_password") @db.VarChar(255)
    isActive       Boolean   @default(false) @map("is_active")
    emailVerified  Boolean   @default(false) @map("email_verified")
    createdAt      DateTime  @default(now()) @map("created_at")
    updatedAt      DateTime  @updatedAt @map("updated_at")
    deletedAt      DateTime? @map("deleted_at")

    characters   Character[]
    chats        Chat[]
    RefreshToken RefreshToken[]

    @@index([email], name: "idx_users_email")
    @@map("users")
}

model Character {
    id           String   @id @default(uuid(7)) @db.VarChar(36)
    name         String   @db.VarChar(64)
    description  String?  @db.VarChar(255)
    instructions String   @map("instructions") @db.VarChar(255)
    userId       String   @map("user_id") @db.VarChar(36)
    createdAt    DateTime @default(now()) @map("created_at")
    updatedAt    DateTime @updatedAt @map("updated_at")

    // TODO: add profile or avatar

    user User   @relation(fields: [userId], references: [id], onDelete: Cascade)
    Chat Chat[]

    @@map("charaters")
}

model Chat {
    id          String   @id @default(uuid(7)) @db.VarChar(36)
    title       String?  @db.VarChar(255)
    userId      String   @map("user_id") @db.VarChar(36)
    characterId String   @map("character_id") @db.VarChar(36)
    createdAt   DateTime @default(now()) @map("created_at")
    updatedAt   DateTime @updatedAt @map("updated_at")

    user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
    character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
    messages  Message[]

    @@index([userId], name: "idx_chats_user_id")
    @@index([characterId], name: "idx_chats_character_id")
    @@map("chats")
}

model Message {
    id        String   @id @default(uuid(7)) @db.VarChar(36)
    role      String   @db.VarChar(32)
    parts     Json     @db.Json
    // attachments Json @db.Json
    chatId    String   @map("chat_id") @db.VarChar(36)
    createdAt DateTime @default(now()) @map("created_at")

    chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

    @@map("messages")
}

model RefreshToken {
    id        String   @id @default(uuid())
    token     String   @unique
    user      User     @relation(fields: [userId], references: [id])
    userId    String   @db.VarChar(36)
    createdAt DateTime @default(now())
    expiresAt DateTime

    @@index([userId], name: "idx_refresh_token_user_id")
    @@map("refresh_tokens")
}
