{
  "name": "ai-chatbot",
  "version": "0.0.1",
  "scripts": {
    "test": "bun test",
    "dev": "bun run --watch src/index.ts",
    "build": "bun build --compile --minify-whitespace --minify-syntax --target bun --outfile ai-chatbot ./src/index.ts",
    "lint": "biome check . && biome format .",
    "format": "biome check --write . && biome format . --write"
  },
  "dependencies": {
    "@elysiajs/cors": "~1.3.3",
    "@elysiajs/jwt": "~1.3.1",
    "@elysiajs/swagger": "~1.3.0",
    "@openai/agents": "~0.0.8",
    "@prisma/client": "~6.10.1",
    "elysia": "~1.3.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.0.5",
    "@types/bun": "~1.2.16",
    "prisma": "~6.10.1"
  },
  "peerDependencies": {
    "typescript": "~5.8.3"
  },
  "module": "src/index.ts"
}
